{
  "name": "node-red-contrib-eelectron-knxip",
  "version": "0.8.0",
  "description": "Stable Node-RED nodes for KNX/IP — UDP tunnelling, KNX IP Secure tunnelling over TCP, ETS-driven DPT auto-encoding, gateway discovery, and typed convenience encoders.",
  "author": "Jamel Nacef <jamel.nacef@eelectron.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eelectronspa/node-red-contrib-eelectron-knxip.git"
  },
  "homepage": "https://github.com/eelectronspa/node-red-contrib-eelectron-knxip#readme",
  "bugs": {
    "url": "https://github.com/eelectronspa/node-red-contrib-eelectron-knxip/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "examples/",
    "images/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "node scripts/run-tests.mjs",
    "lint": "biome check src test",
    "format": "biome format --write src test"
  },
  "node-red": {
    "version": ">=3.0.0",
    "nodes": {
      "eelectron-knxip-config": "dist/nodes/config/config.js",
      "eelectron-knxip-status": "dist/nodes/status/status.js",
      "eelectron-knxip-listener": "dist/nodes/listener/listener.js",
      "eelectron-knxip-writer": "dist/nodes/writer/writer.js",
      "eelectron-knxip-ets-config": "dist/nodes/ets-config/etsConfig.js",
      "eelectron-knxip-ets": "dist/nodes/ets/ets.js",
      "eelectron-knxip-state-store": "dist/nodes/state-store/stateStore.js",
      "eelectron-knxip-scene": "dist/nodes/scene/scene.js",
      "eelectron-knxip-color": "dist/nodes/color/color.js",
      "eelectron-knxip-ets-inject": "dist/nodes/ets-inject/etsInject.js"
    }
  },
  "keywords": [
    "node-red",
    "knx",
    "knxip",
    "knxnet",
    "tunneling",
    "home-automation"
  ],
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "@types/node-red": "^1.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "fast-xml-parser": "^5.7.3"
  }
}
